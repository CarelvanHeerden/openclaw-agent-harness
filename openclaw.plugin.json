{
  "id": "openclaw-agent-harness",
  "name": "OpenClaw Agent Harness",
  "description": "Multi-agent development harness: crystallise -> plan -> execute (Sonnet) -> adversarial review (Fable-5) -> PR.",
  "activation": {
    "onStartup": true
  },
  "skills": [
    "skills/harness-credentials"
  ],
  "contracts": {
    "tools": [
      "harness_run",
      "harness_status",
      "harness_health",
      "harness_start_session",
      "harness_session_get",
      "harness_telemetry",
      "harness_upload_logs",
      "harness_cancel",
      "harness_resume",
      "harness_retention_prune",
      "harness_bootstrap_test_repo",
      "harness_merge_pr"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "slack": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "authorised_users"
        ],
        "properties": {
          "listener_enabled": {
            "type": "boolean",
            "default": false,
            "description": "DEPRECATED as of beta.34: IGNORED. The Slack listener was removed; the harness is tool-driven only (drive it via harness_run / harness_start_session / harness_merge_pr). A `true` value is logged and does nothing. This key is retained only for config back-compat."
          },
          "channel": {
            "type": "string",
            "description": "Slack channel ID (e.g. C0DEVCHAN). Only required when listener_enabled is true."
          },
          "authorised_users": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^U[A-Z0-9]+$"
            },
            "description": "Slack user IDs allowed to open sessions or drop control reactions"
          },
          "credential_service": {
            "type": "string",
            "description": "Vault service name for the Slack bot token. Enables reactions poller."
          },
          "reactions_poll_ms": {
            "type": "integer",
            "minimum": 3000,
            "maximum": 300000,
            "default": 15000
          },
          "reactions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ship_it": {
                "type": "string",
                "default": "rocket"
              },
              "abort": {
                "type": "string",
                "default": "x"
              },
              "pause": {
                "type": "string",
                "default": "pause_button"
              },
              "budget_bump": {
                "type": "string",
                "default": "moneybag"
              }
            }
          }
        }
      },
      "budgets": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "monthly_per_user_usd": {
            "type": "number",
            "minimum": 1
          },
          "session_default_usd": {
            "type": "number",
            "minimum": 1
          },
          "session_hard_ceiling_usd": {
            "type": "number",
            "minimum": 1
          },
          "daily_warn_usd": {
            "type": "number",
            "minimum": 0
          },
          "monthly_warn_ratio": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "repos": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "allowed"
        ],
        "properties": {
          "allowed": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[^/\\s]+/[^/\\s]+$|^[^/\\s]+/\\*$"
            },
            "description": "Repos the harness can touch. Supports owner/repo or owner/* glob."
          },
          "can_create": {
            "type": "boolean",
            "default": false
          },
          "create_org": {
            "type": "string"
          },
          "create_visibility": {
            "type": "string",
            "enum": [
              "private",
              "public"
            ]
          },
          "default_base_branch": {
            "type": "string",
            "default": "main"
          }
        }
      },
      "models": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "lead": {
            "type": "string"
          },
          "worker": {
            "type": "string"
          },
          "adversary": {
            "type": "string"
          },
          "classifier": {
            "type": "string"
          }
        }
      },
      "loop": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "max_cycles": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "default": 3
          },
          "adversarial_pass_ends_early": {
            "type": "boolean",
            "default": true
          },
          "worker_timeout_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 21600,
            "default": 1800
          },
          "adversary_timeout_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 7200,
            "default": 900
          },
          "session_hard_timeout_seconds": {
            "type": "integer",
            "minimum": 300,
            "maximum": 86400,
            "default": 7200
          },
          "subtask_concurrency": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8,
            "default": 1
          }
        }
      },
      "vercel": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "credential_service": {
            "type": "string"
          },
          "api_key_env": {
            "type": "string",
            "default": "VERCEL_TOKEN",
            "description": "Env-var fallback for the Vercel token when the vault is unavailable or empty."
          },
          "team_id": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "preview_wait_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 3600,
            "default": 300
          }
        }
      },
      "storage": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "state_db_path": {
            "type": "string"
          },
          "worktree_root": {
            "type": "string"
          },
          "audit_retention_days": {
            "type": "integer",
            "minimum": 7,
            "maximum": 3650,
            "default": 90
          },
          "prune_terminal_sessions": {
            "type": "boolean",
            "default": false
          },
          "prune_terminal_sessions_days": {
            "type": "integer",
            "minimum": 30,
            "maximum": 3650,
            "default": 365
          }
        }
      },
      "safety": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "worker_permission_mode": {
            "type": "string",
            "enum": [
              "acceptEdits",
              "bypassPermissions",
              "plan"
            ]
          },
          "bash_whitelist": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "bash_denylist_tokens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "path_denylist": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allow_git_push": {
            "type": "boolean",
            "default": false
          },
          "allow_network_commands": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "pat_routing": {
        "type": "object",
        "additionalProperties": true,
        "description": "Git credential routing. beta.25 hierarchical shape (github/gitlab -> org -> person -> {token,name,email,slack_user_id}) plus legacy flat fields. See docs/GITHUB_AUTH.md.",
        "properties": {
          "github": {
            "type": "object",
            "description": "Hierarchical GitHub routing: org -> person -> {token:{value|env|vault}, name, email, slack_user_id}.",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": { "type": "object" }
            }
          },
          "gitlab": {
            "type": "object",
            "description": "Hierarchical GitLab routing: org -> person -> {token:{value|env|vault}, name, email, slack_user_id}.",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": { "type": "object" }
            }
          },
          "overrides": {
            "type": "object",
            "description": "Legacy: { slackUserId: { repoFullNameOrOwner: credentialServiceName } }",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "commit_identity": {
            "type": "object",
            "description": "Legacy per-user commit identity (superseded by hierarchical name/email).",
            "additionalProperties": {
              "type": "object",
              "required": [
                "name",
                "email"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string",
                  "format": "email"
                }
              }
            }
          },
          "user_identities": {
            "type": "object",
            "additionalProperties": { "type": "object" }
          },
          "default_provider": { "type": "string", "enum": ["github", "gitlab"] },
          "provider_by_owner": {
            "type": "object",
            "additionalProperties": { "type": "string", "enum": ["github", "gitlab"] }
          },
          "providers": {
            "type": "object",
            "additionalProperties": { "type": "object" }
          },
          "auth": {
            "type": "object",
            "additionalProperties": true
          },
          "default_service_pattern": {
            "type": "string",
            "default": "github-{owner}"
          }
        }
      }
    }
  }
}
