{
  "id": "openclaw-agent-harness",
  "name": "OpenClaw Agent Harness",
  "description": "Multi-agent development harness: crystallise -> plan -> execute (Sonnet) -> adversarial review (Fable-5) -> PR.",
  "activation": {
    "onStartup": true
  },
  "skills": [
    "skills/harness-credentials"
  ],
  "contracts": {
    "tools": [
      "harness_run",
      "harness_status",
      "harness_progress",
      "harness_health",
      "harness_start_session",
      "harness_session_get",
      "harness_telemetry",
      "harness_upload_logs",
      "harness_cancel",
      "harness_resume",
      "harness_answer",
      "harness_retention_prune",
      "harness_bootstrap_test_repo",
      "harness_merge_pr",
      "harness_list_revisable",
      "harness_revise"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "slack": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "authorised_users"
        ],
        "properties": {
          "listener_enabled": {
            "type": "boolean",
            "default": false,
            "description": "DEPRECATED as of beta.34: IGNORED. The Slack listener was removed; the harness is tool-driven only (drive it via harness_run / harness_start_session / harness_merge_pr). A `true` value is logged and does nothing. This key is retained only for config back-compat."
          },
          "channel": {
            "type": "string",
            "description": "Slack channel ID (e.g. C0DEVCHAN). Only required when listener_enabled is true."
          },
          "authorised_users": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^U[A-Z0-9]+$"
            },
            "description": "Slack user IDs allowed to open sessions or drop control reactions"
          },
          "credential_service": {
            "type": "string",
            "description": "Vault service name for the Slack bot token. Enables reactions poller."
          },
          "reactions_poll_ms": {
            "type": "integer",
            "minimum": 3000,
            "maximum": 300000,
            "default": 15000
          },
          "reactions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ship_it": {
                "type": "string",
                "default": "rocket"
              },
              "abort": {
                "type": "string",
                "default": "x"
              },
              "pause": {
                "type": "string",
                "default": "pause_button"
              },
              "budget_bump": {
                "type": "string",
                "default": "moneybag"
              }
            }
          }
        }
      },
      "budgets": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "monthly_per_user_usd": {
            "type": "number",
            "minimum": 1
          },
          "session_default_usd": {
            "type": "number",
            "minimum": 1
          },
          "session_hard_ceiling_usd": {
            "type": "number",
            "minimum": 1
          },
          "daily_warn_usd": {
            "type": "number",
            "minimum": 0
          },
          "daily_max_usd": {
            "type": "number",
            "minimum": 0,
            "default": 200,
            "description": "Hard daily spend ceiling (USD); basis for the deploy-repair budget. Must be >= daily_warn_usd."
          },
          "monthly_warn_ratio": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "repos": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "allowed"
        ],
        "properties": {
          "allowed": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[^/\\s]+/[^/\\s]+$|^[^/\\s]+/\\*$"
            },
            "description": "Repos the harness can touch. Supports owner/repo or owner/* glob."
          },
          "can_create": {
            "type": "boolean",
            "default": false
          },
          "create_org": {
            "type": "string"
          },
          "create_visibility": {
            "type": "string",
            "enum": [
              "private",
              "public"
            ]
          },
          "default_base_branch": {
            "type": "string",
            "default": "main"
          }
        }
      },
      "models": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "lead": {
            "type": "string"
          },
          "worker": {
            "type": "string"
          },
          "adversary": {
            "type": "string"
          },
          "classifier": {
            "type": "string"
          },
          "price_overrides": {
            "type": "object",
            "description": "Per-model price overrides for cost estimation, keyed by model id. Values are USD per million tokens.",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": ["input", "output"],
              "properties": {
                "input": { "type": "number", "minimum": 0 },
                "output": { "type": "number", "minimum": 0 }
              }
            }
          },
          "auth": {
            "type": "object",
            "additionalProperties": false,
            "description": "Anthropic auth for the embedded Claude Agent SDK. Vault-first (credential_service), env fallback (api_key_env, default ANTHROPIC_API_KEY).",
            "properties": {
              "credential_service": { "type": "string" },
              "api_key_env": { "type": "string", "default": "ANTHROPIC_API_KEY" }
            }
          }
        }
      },
      "loop": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "max_cycles": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "default": 3
          },
          "adversarial_pass_ends_early": {
            "type": "boolean",
            "default": true
          },
          "worker_timeout_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 21600,
            "default": 1800
          },
          "adversary_timeout_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 7200,
            "default": 900
          },
          "lead_timeout_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 7200,
            "default": 900,
            "description": "beta.43: max seconds the lead-planner SDK call may run before it is treated as a hang and the run fails cleanly (loop.lead_timeout). The lead await was unbounded (beta.42 only bounded the worker); a healthy long plan was indistinguishable from a wedge."
          },
          "session_hard_timeout_seconds": {
            "type": "integer",
            "minimum": 300,
            "maximum": 86400,
            "default": 7200
          },
          "subtask_concurrency": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8,
            "default": 1
          },
          "stuck_loop_seconds": {
            "type": "integer",
            "minimum": 300,
            "maximum": 86400,
            "default": 2700,
            "description": "beta.40: reclaim threshold for a wedged loop. If run() is asked to start a session still marked running by the module-level re-entrancy guard, but its last_checkpoint_at/updated_at has not advanced for this many seconds, the tracked loop is treated as dead (torn down with a prior runtime on plugin re-register), the stale guard entry is force-cleared, and the fresh run proceeds. Must exceed a normal long worker SDK call so a busy loop is never reclaimed."
          },
          "teardown_drain_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 86400,
            "default": 3600,
            "description": "beta.41: max seconds teardown() waits for a still-running loop from the runtime being torn down to finish before closing its state DB. A plugin re-register (OKF / gateway auto-discovery churn when plugins.allow is empty) schedules a fire-and-forget teardown of the previous runtime; closing the DB out from under an in-flight loop.run() crashes the run. Draining first prevents that. Bounded so a wedged loop can't block teardown forever."
          },
          "stall_watchdog_seconds": {
            "type": "integer",
            "minimum": 10,
            "maximum": 3600,
            "default": 90,
            "description": "beta.42: active stall-watchdog delay. When the re-entrancy guard skips a re-entry (loop.run_skipped_already_running) it arms a timer for this long, then re-checks the session's progress; if none, the wedged loop's stale guard handle is force-deregistered (loop.wedge_detected) so recovery/next-run can reclaim it. Makes beta.40's passive reclaim active -- a loop that wedges with no further re-register is now noticed."
          },
          "env_wait_retry_enabled": {
            "type": "boolean",
            "default": true,
            "description": "beta.53 (P1b): when a worker ends its turn awaiting a non-existent mid-turn 'Monitor event' (env-wait hallucination) and made no committed change, re-invoke the sub-task ONCE with corrective context (branched on whether it wrote-but-didn't-commit) instead of failing the run. Set false to disable the retry; the failure is still tagged loop.worker_env_wait_hallucination."
          },
          "clarification_escalation_enabled": {
            "type": "boolean",
            "default": true,
            "description": "beta.55 (B2): when a worker refuses/confabulates a sub-task even after the beta.54 async-coord retry, pause the session in 'awaiting_clarification' (persisting the worker's question + paused seq, preserving the worktree) and surface it via harness_progress for a human to answer with harness_answer, instead of hard-failing the run. Set false to keep the terminal-fail behaviour."
          }
        }
      },
      "vercel": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "credential_service": {
            "type": "string"
          },
          "api_key_env": {
            "type": "string",
            "default": "VERCEL_TOKEN",
            "description": "Env-var fallback for the Vercel token when the vault is unavailable or empty."
          },
          "team_id": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "preview_wait_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 3600,
            "default": 300
          },
          "deploy_repair": {
            "type": "object",
            "additionalProperties": false,
            "description": "beta.36: post-merge deploy-repair loop. On a merged PR whose Vercel deploy ERRORs, auto-attempt fixes (up to max_attempts new PRs) from the build logs; if still failing, revert all merges and leave the last attempt open for review.",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10, "default": 3 },
              "budget_ratio": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.25, "description": "Repair budget as a fraction of budgets.daily_max_usd, shared across all attempts." }
            }
          }
        }
      },
      "storage": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "state_db_path": {
            "type": "string"
          },
          "worktree_root": {
            "type": "string"
          },
          "audit_retention_days": {
            "type": "integer",
            "minimum": 7,
            "maximum": 3650,
            "default": 90
          },
          "prune_terminal_sessions": {
            "type": "boolean",
            "default": false
          },
          "prune_terminal_sessions_days": {
            "type": "integer",
            "minimum": 30,
            "maximum": 3650,
            "default": 365
          }
        }
      },
      "safety": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "worker_permission_mode": {
            "type": "string",
            "enum": [
              "acceptEdits",
              "bypassPermissions",
              "plan"
            ]
          },
          "bash_whitelist": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "bash_denylist_tokens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "path_denylist": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allow_git_push": {
            "type": "boolean",
            "default": false
          },
          "allow_network_commands": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "pat_routing": {
        "type": "object",
        "additionalProperties": true,
        "description": "Git credential routing. beta.25 hierarchical shape (github/gitlab -> org -> person -> {token,name,email,slack_user_id}) plus legacy flat fields. See docs/GITHUB_AUTH.md.",
        "properties": {
          "github": {
            "type": "object",
            "description": "Hierarchical GitHub routing: org -> person -> {token:{value|env|vault}, name, email, slack_user_id}.",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": { "type": "object" }
            }
          },
          "gitlab": {
            "type": "object",
            "description": "Hierarchical GitLab routing: org -> person -> {token:{value|env|vault}, name, email, slack_user_id}.",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": { "type": "object" }
            }
          },
          "overrides": {
            "type": "object",
            "description": "Legacy: { slackUserId: { repoFullNameOrOwner: credentialServiceName } }",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "commit_identity": {
            "type": "object",
            "description": "Legacy per-user commit identity (superseded by hierarchical name/email).",
            "additionalProperties": {
              "type": "object",
              "required": [
                "name",
                "email"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string",
                  "format": "email"
                }
              }
            }
          },
          "user_identities": {
            "type": "object",
            "additionalProperties": { "type": "object" }
          },
          "default_provider": { "type": "string", "enum": ["github", "gitlab"] },
          "provider_by_owner": {
            "type": "object",
            "additionalProperties": { "type": "string", "enum": ["github", "gitlab"] }
          },
          "providers": {
            "type": "object",
            "additionalProperties": { "type": "object" }
          },
          "auth": {
            "type": "object",
            "additionalProperties": true
          },
          "default_service_pattern": {
            "type": "string",
            "default": "github-{owner}"
          }
        }
      },
      "logging": {
        "type": "object",
        "additionalProperties": false,
        "description": "Harness log verbosity. 'debug' makes error sites log full error objects.",
        "properties": {
          "level": {
            "type": "string",
            "enum": ["debug", "info", "warn", "error"],
            "default": "info"
          }
        }
      }
    }
  }
}
