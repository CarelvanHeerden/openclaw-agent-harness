{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ai/schemas/harness/config.json",
  "title": "openclaw-agent-harness config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "slack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorised_users"],
      "properties": {
        "listener_enabled": {
          "type": "boolean",
          "default": false,
          "description": "When true, the plugin listens to `channel` and treats allow-listed messages as dev requests (autonomous mode). When false (default), the OpenClaw agent orchestrates the harness via tools and the plugin does not listen to Slack."
        },
        "channel": { "type": "string", "description": "Slack channel ID (e.g. C0DEVCHAN). Only required when listener_enabled is true." },
        "authorised_users": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^U[A-Z0-9]+$" },
          "description": "Slack user IDs allowed to open sessions or drop control reactions"
        },
        "credential_service": { "type": "string", "description": "Vault service name for the Slack bot token. Enables reactions poller." },
        "reactions_poll_ms": { "type": "integer", "minimum": 3000, "maximum": 300000, "default": 15000 },
        "reactions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ship_it": { "type": "string", "default": "rocket" },
            "abort": { "type": "string", "default": "x" },
            "pause": { "type": "string", "default": "pause_button" },
            "budget_bump": { "type": "string", "default": "moneybag" }
          }
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "monthly_per_user_usd": { "type": "number", "minimum": 1 },
        "session_default_usd": { "type": "number", "minimum": 1 },
        "session_hard_ceiling_usd": { "type": "number", "minimum": 1 },
        "daily_warn_usd": { "type": "number", "minimum": 0 },
        "monthly_warn_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "repos": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed"],
      "properties": {
        "allowed": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$|^[^/\\s]+/\\*$" },
          "description": "Repos the harness can touch. Supports owner/repo or owner/* glob."
        },
        "can_create": { "type": "boolean", "default": false },
        "create_org": { "type": "string" },
        "create_visibility": { "type": "string", "enum": ["private", "public"] },
        "default_base_branch": { "type": "string", "default": "main" },
        "draft_pr_on_nonpass": { "type": "boolean", "default": false }
      }
    },
    "logging": {
      "type": "object",
      "description": "beta.24: harness log verbosity. When level='debug', SDK errors (crystallise, lead, worker, adversary) log their full error object instead of a one-line summary. Vault-lookup and pat-routing failures also log the exact keys tried. Set to 'debug' during smoke testing to make credential + planner failures diagnosable without a code change.",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "description": "Minimum log level the harness emits. Defaults to 'info' (current behaviour)."
        }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lead": { "type": "string" },
        "worker": { "type": "string" },
        "adversary": { "type": "string" },
        "classifier": { "type": "string" },
        "auth": {
          "type": "object",
          "description": "beta.4+ addition, beta.24 schema fix. Anthropic API key resolution: vault-first, then env fallback. Both fields optional; when omitted, harness relies solely on env (ANTHROPIC_API_KEY) or SDK default behaviour.",
          "additionalProperties": false,
          "properties": {
            "credential_service": {
              "type": "string",
              "description": "Vault service name for the Anthropic API key. Vault-first lookup key."
            },
            "api_key_env": {
              "type": "string",
              "description": "Environment variable to read on vault miss. Defaults to ANTHROPIC_API_KEY."
            }
          }
        }
      }
    },
    "loop": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_cycles": { "type": "integer", "minimum": 1, "maximum": 10, "default": 3 },
        "adversarial_pass_ends_early": { "type": "boolean", "default": true },
        "worker_timeout_seconds": { "type": "integer", "minimum": 30, "maximum": 21600, "default": 1800 },
        "adversary_timeout_seconds": { "type": "integer", "minimum": 30, "maximum": 7200, "default": 900 },
        "session_hard_timeout_seconds": { "type": "integer", "minimum": 300, "maximum": 86400, "default": 7200 },
        "subtask_concurrency": { "type": "integer", "minimum": 1, "maximum": 8, "default": 1 }
      }
    },
    "vercel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "credential_service": { "type": "string" },
        "api_key_env": { "type": "string", "default": "VERCEL_TOKEN", "description": "Env-var fallback for the Vercel token when the vault is unavailable or empty." },
        "team_id": { "type": "string" },
        "project_id": { "type": "string" },
        "preview_wait_seconds": { "type": "integer", "minimum": 30, "maximum": 3600, "default": 300 }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state_db_path": { "type": "string" },
        "worktree_root": { "type": "string" },
        "audit_retention_days": { "type": "integer", "minimum": 7, "maximum": 3650, "default": 90 },
        "prune_terminal_sessions": { "type": "boolean", "default": false },
        "prune_terminal_sessions_days": { "type": "integer", "minimum": 30, "maximum": 3650, "default": 365 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "worker_permission_mode": { "type": "string", "enum": ["acceptEdits", "bypassPermissions", "plan"] },
        "bash_whitelist": { "type": "array", "items": { "type": "string" } },
        "bash_denylist_tokens": { "type": "array", "items": { "type": "string" } },
        "path_denylist": { "type": "array", "items": { "type": "string" } },
        "allow_git_push": { "type": "boolean", "default": false },
        "allow_network_commands": { "type": "boolean", "default": false }
      }
    },
    "pat_routing": {
      "type": "object",
      "additionalProperties": false,
      "$defs": {
        "personToken": {
          "type": "object",
          "additionalProperties": false,
          "required": ["token", "name", "email"],
          "properties": {
            "token": {
              "type": "object",
              "additionalProperties": false,
              "description": "Exactly one of value | env | vault.",
              "properties": {
                "value": { "type": "string", "description": "Inline secret (single-operator; setter accepts risk)." },
                "env": { "type": "string", "description": "Env var name holding the token." },
                "vault": { "type": "string", "description": "Credential-vault service name (requires memory-hybrid)." }
              },
              "minProperties": 1,
              "maxProperties": 1
            },
            "name": { "type": "string", "description": "Git commit author name." },
            "email": { "type": "string", "format": "email", "description": "Git commit author email (required)." },
            "slack_user_id": { "type": "string", "description": "Slack user id mapping an inbound request to this person. Auto-captured in vault/self-write tiers; manual in copy-paste tier." }
          }
        },
        "orgMap": {
          "type": "object",
          "description": "Repo owner/org -> { person: PersonToken }.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "$ref": "#/properties/pat_routing/$defs/personToken" }
          }
        }
      },
      "properties": {
        "github": { "$ref": "#/properties/pat_routing/$defs/orgMap", "description": "beta.25 hierarchical GitHub routing: org -> person -> token." },
        "gitlab": { "$ref": "#/properties/pat_routing/$defs/orgMap", "description": "beta.25 hierarchical GitLab routing: org -> person -> token." },
        "overrides": {
          "type": "object",
          "description": "Legacy: { slackUserId: { repoFullNameOrOwner: credentialServiceName } }",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "commit_identity": {
          "type": "object",
          "description": "Legacy per-user commit identity (superseded by hierarchical name/email).",
          "additionalProperties": {
            "type": "object",
            "required": ["name", "email"],
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            }
          }
        },
        "user_identities": {
          "type": "object",
          "description": "Legacy: { slackUserId: { github?: login, gitlab?: login } }",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "default_provider": { "type": "string", "enum": ["github", "gitlab"] },
        "provider_by_owner": {
          "type": "object",
          "additionalProperties": { "type": "string", "enum": ["github", "gitlab"] }
        },
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "api_base": { "type": "string" },
              "api_key_env": { "type": "string" }
            }
          }
        },
        "auth": {
          "type": "object",
          "properties": { "api_key_env": { "type": "string" } }
        },
        "default_service_pattern": { "type": "string", "default": "github-{owner}" }
      }
    }
  }
}
