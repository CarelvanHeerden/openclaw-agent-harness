{
  "name": "openclaw-agent-harness",
  "version": "0.1.0-beta.1",
  "description": "Multi-agent orchestration harness. Fable-5 lead + Sonnet workers + adversarial reviewer, driven from Slack.",
  "entry": "dist/index.js",
  "requires": {
    "openclaw": ">=2026.6.0",
    "node": ">=20.0.0"
  },
  "config_schema": "src/config.schema.json",
  "provides": {
    "tools": [
      "harness_status",
      "harness_health",
      "harness_start_session",
      "harness_session_get",
      "harness_telemetry",
      "harness_upload_logs",
      "harness_cancel",
      "harness_resume",
      "harness_retention_prune"
    ],
    "hooks": [
      "message.received"
    ],
    "services": [
      "openclaw-agent-harness:reactions-poller",
      "openclaw-agent-harness:pr-watcher",
      "openclaw-agent-harness:retention-nightly"
    ]
  },
  "license": "MIT",
  "repository": "https://github.com/CarelvanHeerden/openclaw-agent-harness"
}
