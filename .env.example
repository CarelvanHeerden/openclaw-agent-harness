# Anthropic API key used by the Claude Agent SDK
ANTHROPIC_API_KEY=

# Optional: separate key just for the harness (falls back to ANTHROPIC_API_KEY)
OAH_ANTHROPIC_API_KEY=

# Optional: override state DB path (defaults to storage.state_db_path from config)
OAH_STATE_DB=

# Optional: override log level: debug | info | warn | error
OAH_LOG_LEVEL=info
