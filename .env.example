# Anthropic API key used by the Claude Agent SDK
ANTHROPIC_API_KEY=

# Optional: separate key just for the harness (falls back to ANTHROPIC_API_KEY)
OAH_ANTHROPIC_API_KEY=

# GitHub token env fallback (used when the vault lookup for the resolved
# pat_routing service fails/returns nothing). Name overridable via
# pat_routing.auth.api_key_env. Needs repo scope (contents:write, pull_requests).
# See docs/GITHUB_AUTH.md.
GH_TOKEN=

*** GitLab token env fallback (used for gitlab-provider repos when the vault
# lookup fails). Name overridable via pat_routing.providers.gitlab.api_key_env.
# Env fallback is a single shared token per provider; true per-user auth is
# vault-backed. See docs/GITHUB_AUTH.md.
GITLAB_TOKEN=

# Optional: override state DB path (defaults to storage.state_db_path from config)
OAH_STATE_DB=

# Optional: override log level: debug | info | warn | error
OAH_LOG_LEVEL=info
