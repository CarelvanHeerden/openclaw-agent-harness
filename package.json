{
  "name": "openclaw-agent-harness",
  "version": "0.0.1",
  "description": "Multi-agent orchestration harness for OpenClaw. Fable-5 lead + Sonnet workers + adversarial reviewer, driven from Slack.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "plugin.json",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/",
    "lint": "eslint 'src/**/*.ts'",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "agent-harness",
    "claude",
    "claude-agent-sdk",
    "multi-agent",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CarelvanHeerden/openclaw-agent-harness.git"
  },
  "license": "MIT",
  "author": "Carel van Heerden"
}
